# Loaded automatically by `npm run dev`.
# Connects the frontend to the local Django backend (no Docker needed):
#   Terminal 1:  cd backend && source .venv/bin/activate && python manage.py runserver
#   Terminal 2:  npm run dev
#
# To run the frontend standalone in mock mode instead, create a .env.local with
#   NEXT_PUBLIC_BACKEND_READY=false
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_BACKEND_READY=true
