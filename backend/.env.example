# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — leave DATABASE_URL unset to use local SQLite (dev convenience).
# DATABASE_URL=postgres://mealbuddy:mealbuddy@localhost:5432/mealbuddy

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=True

# CORS / frontend
CORS_ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Email (console backend in dev)
DEFAULT_FROM_EMAIL=MealBuddy <no-reply@mealbuddy.app>

# JWT lifetimes (minutes / days)
ACCESS_TOKEN_LIFETIME_MIN=15
REFRESH_TOKEN_LIFETIME_DAYS=7
